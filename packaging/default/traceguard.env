# TraceGuard environment configuration.
# Leave TRACEGUARD_BLOCK=false for observe-only mode.
# Set TRACEGUARD_BLOCK_ALL=true for deny-all DNS/resolver policy with explicit allow rules.

TRACEGUARD_BLOCK=false
TRACEGUARD_BLOCK_ALL=false
TRACEGUARD_DRY_RUN=false
TRACEGUARD_BLOCKLIST_URL=
TRACEGUARD_BLOCK_DOMAINS=
TRACEGUARD_ALLOW_DOMAINS=
TRACEGUARD_CACHE_PATH=/var/lib/traceguard/blocklist.txt
TRACEGUARD_REFRESH_INTERVAL=6h
TRACEGUARD_CGROUP_PATH=/sys/fs/cgroup
TRACEGUARD_LOG_PATH=/var/log/traceguard/traceguard.log
TRACEGUARD_LOG_FORMAT=json
TRACEGUARD_METRICS_ADDR=:9091
TRACEGUARD_EVENT_ARCHIVE_PATH=
TRACEGUARD_EVENT_EXPORT_URL=
TRACEGUARD_EVENT_EXPORT_AUTH_HEADER=Authorization
TRACEGUARD_EVENT_EXPORT_AUTH_TOKEN=
TRACEGUARD_EVENT_EXPORT_BATCH_SIZE=50
TRACEGUARD_EVENT_EXPORT_FLUSH_INTERVAL=5s
TRACEGUARD_EVENT_EXPORT_SPOOL_PATH=/var/lib/traceguard/export-spool
TRACEGUARD_EVENT_EXPORT_CA_PATH=
TRACEGUARD_EVENT_EXPORT_CLIENT_CERT=
TRACEGUARD_EVENT_EXPORT_CLIENT_KEY=
TRACEGUARD_EVENT_EXPORT_GZIP=false
TRACEGUARD_PROCESS_CACHE_TTL=10m
TRACEGUARD_KUBERNETES_ENRICH=false
TRACEGUARD_KUBERNETES_API_URL=
TRACEGUARD_KUBERNETES_TOKEN_PATH=/var/run/secrets/kubernetes.io/serviceaccount/token
TRACEGUARD_KUBERNETES_CA_PATH=/var/run/secrets/kubernetes.io/serviceaccount/ca.crt
TRACEGUARD_KUBERNETES_NODE_NAME=
TRACEGUARD_KUBERNETES_POLL_INTERVAL=2m
